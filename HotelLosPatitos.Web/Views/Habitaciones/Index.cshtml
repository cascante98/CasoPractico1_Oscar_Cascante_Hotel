@model List<HotelLosPatitos.Entities.Habitacion>
@{
    ViewData["Title"] = "Habitaciones";
}

<h1>Habitaciones</h1>

<p>
    <a asp-action="Registrar" class="btn btn-primary">Registrar habitación</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay habitaciones registradas.</div>
}
else
{
    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Ubicación</th>
                <th>Huéspedes</th>
                <th>Camas</th>
                <th>Baños</th>
                <th>Encargado limpieza</th>
                <th>Costo limpieza</th>
                <th>Costo reserva</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var habitacion in Model)
            {
                <tr>
                    <td>@habitacion.CodigoDeHabitacion</td>
                    <td>@habitacion.NombreDeHabitacion</td>
                    <td>@habitacion.Ubicacion</td>
                    <td>@habitacion.CantidadDeHuespedesPermitidos</td>
                    <td>@habitacion.CantidadDeCamas</td>
                    <td>@habitacion.CantidadDeBanos</td>
                    <td>@habitacion.EncargadoDeLimpieza</td>
                    <td>@habitacion.CostoDeLimpieza.ToString("N2")</td>
                    <td>@habitacion.CostoDeReserva.ToString("N2")</td>
                    <td>
                        @(habitacion.TipoDeHabitacion switch
                        {
                            1 => "Junior",
                            2 => "Superior",
                            3 => "Suite",
                            _ => "Desconocido"
                        })
                    </td>
                    <td>
                        @if (habitacion.Estado)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        <a asp-action="Editar" asp-route-id="@habitacion.Id"
                           class="btn btn-sm btn-warning">Editar</a>
                        <a asp-controller="ReservaAdministrativa" asp-action="Index"
                           asp-route-id="@habitacion.Id" class="btn btn-sm btn-info">Ver reservas</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}